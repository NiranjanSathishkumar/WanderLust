<% layout("/layouts/boilerplate") -%>

<div class="form-page-wrapper">
  <h1 class="form-page-title">
    <i class="fa-solid fa-pen-to-square me-2" style="color: var(--color-coral);"></i>
    Edit Listing
  </h1>

  <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data">

    <div class="form-group">
      <label class="form-label" for="title">Title</label>
      <input
        required
        class="form-control"
        type="text"
        name="listing[title]"
        id="title"
        placeholder="Listing title"
        value="<%= listing.title %>"
      />
      <div class="invalid-feedback">Please provide a title.</div>
    </div>

    <div class="form-group">
      <label class="form-label" for="description">Description</label>
      <textarea
        required
        class="form-control"
        name="listing[description]"
        id="description"
        rows="5"
        placeholder="Describe your space"
      ><%= listing.description %></textarea>
      <div class="invalid-feedback">Please add a description.</div>
    </div>

    <div class="form-group">
      <label class="form-label">Current Image</label>
      <img
        src="<%= listing.image.url %>"
        alt="Current listing image"
        class="current-img-preview d-block"
      />
    </div>

    <div class="form-group">
      <label class="form-label" for="image">Replace Image</label>
      <input class="form-control" type="file" name="listing[image]" id="image" />
    </div>

    <div class="form-group">
      <label class="form-label" for="price">Price per Night (&#8377;)</label>
      <input
        required
        class="form-control"
        type="number"
        name="listing[price]"
        id="price"
        placeholder="Price"
        value="<%= listing.price %>"
        min="0"
      />
      <div class="invalid-feedback">Please enter a valid price.</div>
    </div>

    <div class="row">
      <div class="col-md-5 form-group">
        <label class="form-label" for="location">City / Area</label>
        <input
          required
          class="form-control"
          type="text"
          name="listing[location]"
          id="location"
          placeholder="Location"
          value="<%= listing.location %>"
        />
        <div class="invalid-feedback">Please enter a location.</div>
      </div>

      <div class="col-md-7 form-group">
        <label class="form-label" for="country">Country</label>
        <input
          required
          class="form-control"
          type="text"
          name="listing[country]"
          id="country"
          placeholder="Country"
          value="<%= listing.country %>"
        />
        <div class="invalid-feedback">Please enter a country.</div>
      </div>
    </div>

    <div class="d-flex gap-3 mt-4">
      <button class="btn btn-primary" type="submit">
        <i class="fa-solid fa-floppy-disk me-2"></i>Save Changes
      </button>
      <a href="/listings/<%= listing._id %>" class="btn btn-ghost">Cancel</a>
    </div>

  </form>
</div>
