<% if(success && success.length) { %>
<div class="alert alert-wl alert-success alert-dismissible fade show" role="alert" id="wl-flash-success">
  <i class="fa-solid fa-circle-check alert-icon"></i>
  <span><%= success %></span>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);"></button>
  <div class="alert-wl-progress"></div>
</div>
<% } %>

<% if(error && error.length) { %>
<div class="alert alert-wl alert-danger alert-dismissible fade show" role="alert" id="wl-flash-error">
  <i class="fa-solid fa-circle-exclamation alert-icon"></i>
  <span><%= error %></span>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);"></button>
  <div class="alert-wl-progress"></div>
</div>
<% } %>